# Database (Neon / Vercel Postgres)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Vercel Blob (optional for uploads and export zip)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Google Gemini API (optional - for AI image generation with Nano Banana 2)
GEMINI_API_KEY="your_gemini_api_key_here"

# OpenAI API (optional - for content generation)
OPENAI_API_KEY="sk-..."

# OpenAI model for course import (default: gpt-5-mini)
# Other options: gpt-5, gpt-5-nano, gpt-4o
OPENAI_IMPORT_MODEL="gpt-5-mini"
